{
  "name": "coding-sdk",
  "version": "0.1.0",
  "description": "ESM-first SDK for CODING Open API.",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./errors": {
      "types": "./dist/core/errors.d.ts",
      "import": "./dist/core/errors.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "import": "./dist/schemas/index.js"
    },
    "./schemas/user": {
      "types": "./dist/schemas/user.d.ts",
      "import": "./dist/schemas/user.js"
    },
    "./schemas/issues": {
      "types": "./dist/schemas/issues.d.ts",
      "import": "./dist/schemas/issues.js"
    },
    "./schemas/serviceHooks": {
      "types": "./dist/schemas/serviceHooks.d.ts",
      "import": "./dist/schemas/serviceHooks.js"
    },
    "./apis/user": {
      "types": "./dist/apis/user/index.d.ts",
      "import": "./dist/apis/user/index.js"
    },
    "./apis/issues": {
      "types": "./dist/apis/issues/index.d.ts",
      "import": "./dist/apis/issues/index.js"
    },
    "./apis/serviceHooks": {
      "types": "./dist/apis/serviceHooks/index.d.ts",
      "import": "./dist/apis/serviceHooks/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "codegen:manifest": "node ./scripts/codegen/extract-action-manifest.mjs",
    "codegen:action": "node ./scripts/codegen/generate-action-module.mjs",
    "codegen:schema": "node ./scripts/codegen/generate-shared-schema-module.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build"
  },
  "dependencies": {
    "effect": "^3.13.10"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2",
    "yaml": "^2.8.1"
  }
}